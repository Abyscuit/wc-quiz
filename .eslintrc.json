{
  "rules": {
    "eqeqeq": [
      2,
      "allow-null"
    ],
    "indent": [
      2,
      2
    ],
    "semi": [
      2,
      "always"
    ],
    "no-console": "error",
    "react/jsx-key": "off",
    "react/no-unescaped-entities": "off",
    "@next/next/no-img-element": "off"
  },
  "extends": [
    "next/core-web-vitals",
    "next/typescript",
    "plugin:prettier/recommended",
    "prettier"
  ]
}